{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IntentEngineContract",
  "type": "object",
  "required": [
    "intent",
    "plan",
    "verification"
  ],
  "properties": {
    "intent": {
      "type": "object",
      "required": [
        "id",
        "domain",
        "objective",
        "risk_tier"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "domain": {
          "type": "string"
        },
        "objective": {
          "type": "string"
        },
        "inputs": {
          "type": "object"
        },
        "constraints": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "success": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "risk_tier": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "critical"
          ]
        },
        "ambiguity_policy": {
          "type": "string",
          "enum": [
            "clarify",
            "assume_conservative",
            "best_effort"
          ]
        },
        "contradiction_policy": {
          "type": "string",
          "enum": [
            "flag_and_pause",
            "choose_highest_authority",
            "merge_with_notes"
          ]
        },
        "require_evidence": {
          "type": "boolean"
        },
        "require_human_review": {
          "type": "boolean"
        },
        "output_format": {
          "type": [
            "string",
            "null"
          ]
        },
        "personal_intent": {
          "type": "object",
          "required": [
            "modes"
          ],
          "properties": {
            "modes": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "ship",
                  "learn",
                  "explore",
                  "refactor",
                  "stabilize",
                  "mentor",
                  "document",
                  "de-risk"
                ]
              }
            },
            "values": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "tradeoffs": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "axis",
                  "preference"
                ],
                "properties": {
                  "axis": {
                    "type": "string"
                  },
                  "preference": {
                    "type": "string"
                  },
                  "notes": {
                    "type": "string"
                  }
                }
              }
            },
            "anti_goals": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "definition_of_done": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "energy_budget": {
              "type": "string",
              "enum": [
                "low",
                "medium",
                "high"
              ]
            },
            "time_horizon": {
              "type": "string",
              "enum": [
                "today",
                "this_week",
                "this_month",
                "long_term"
              ]
            },
            "confidence": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            }
          }
        }
      }
    },
    "plan": {
      "type": "object",
      "required": [
        "id",
        "intent_id",
        "steps"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "intent_id": {
          "type": "string"
        },
        "steps": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "tool",
              "action",
              "args"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "tool": {
                "type": "string"
              },
              "action": {
                "type": "string"
              },
              "args": {
                "type": "object"
              },
              "depends_on": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "can_fail": {
                "type": "boolean"
              }
            }
          }
        },
        "rationale": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "verification": {
      "type": "object",
      "required": [
        "decision",
        "score"
      ],
      "properties": {
        "decision": {
          "type": "string",
          "enum": [
            "accept",
            "revise",
            "clarify",
            "escalate",
            "refuse"
          ]
        },
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "failed_checks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "required_clarifications": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}